# Valheim Server Environment Variables
# Copy this to .env and fill in your values — never commit .env

# Server display name
SERVER_NAME=

# World save name
WORLD_NAME=

# Server password
SERVER_PASS=

# UDP ports (Valheim uses two consecutive ports)
VALHEIM_PORT=
VALHEIM_PORT_PLUS1=

# Timezone (e.g. America/Chicago)
TZ=
